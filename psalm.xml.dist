<?xml version="1.0"?>
<psalm
  errorLevel="8"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="https://getpsalm.org/schema/config"
  xsi:schemaLocation="https://getpsalm.org/schema/config vendor-bin/psalm/vendor/vimeo/psalm/config.xsd"
  findUnusedBaselineEntry="true"
  findUnusedCode="false"
>
  <projectFiles>
    <directory name="Common"/>
    <directory name="Scripts"/>
    <directory name="test"/>
    <ignoreFiles>
      <directory name="vendor"/>
      <file name="Common/src/Common/Form/Elements/Validators/EmailConfirm.php" />
      <file name="Common/src/Common/Form/Elements/Validators/FeeAmountValidator.php" />
      <file name="Common/src/Common/Form/Elements/Validators/FeeExactAmountValidator.php" />
      <file name="Common/src/Common/Form/Elements/Validators/NoOfPermitsMax.php" />
      <file name="Common/src/Common/Form/Elements/Validators/NoOfPermitsMin.php" />
      <file name="Common/src/Common/Form/Elements/Validators/NoOfPermitsNotEmpty.php" />
      <file name="Common/src/Common/Form/Elements/Validators/PasswordConfirm.php" />
      <file name="Common/src/Common/Form/Elements/Validators/ReceivedAmount.php" />
    </ignoreFiles>
  </projectFiles>
</psalm>

